Bootstrap: docker
From: perl@sha256:152d2399b1e9db0d585bf51de8464af4858037b72b74e43111ea12913c16d02d
Stage: perl

Bootstrap: docker
From: multiqc/multiqc@sha256:a0c146fb9ec0207a88627da3aaa36c10014c5ef8dc841c55a01c0345d8b5cae5
Stage: final

%files from perl
    /usr/local/bin/perl /opt/perl/bin/perl
    /usr/local/lib/perl5 /usr/local/lib/perl5

%files
    .build/sources/fastqc_v0.12.1.zip /opt/sources/fastqc_v0.12.1.zip
    .build/sources/fastp.1.3.6 /opt/sources/fastp.1.3.6
    .build/sources/OpenJDK17U-jre_x64_linux_hotspot_17.0.19_10.tar.gz /opt/sources/jre.tar.gz

%post
    set -eu

    apt-get update
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        fontconfig=2.15.0-2.3 \
        fontconfig-config=2.15.0-2.3 \
        fonts-dejavu-core=2.37-8 \
        libfontconfig1=2.15.0-2.3
    rm -rf /var/lib/apt/lists/*

    mkdir -p /opt/fastqc /opt/java
    python -m zipfile -e /opt/sources/fastqc_v0.12.1.zip /opt
    mv /opt/FastQC/* /opt/fastqc/
    rmdir /opt/FastQC
    tar -xzf /opt/sources/jre.tar.gz --strip-components=1 -C /opt/java

    install -m 0755 /opt/sources/fastp.1.3.6 /usr/local/bin/fastp
    chmod 0755 /opt/fastqc/fastqc
    cat > /usr/local/bin/fastqc <<'EOF'
#!/bin/sh
LD_LIBRARY_PATH=/usr/local/lib/perl5/5.40.3/x86_64-linux-gnu/CORE \
    exec /opt/perl/bin/perl /opt/fastqc/fastqc "$@"
EOF
    chmod 0755 /usr/local/bin/fastqc
    rm -rf /opt/sources

%environment
    export JAVA_HOME=/opt/java
    export PATH=/usr/local/bin:/opt/java/bin:/opt/fastqc:/usr/bin:/bin
    export PYTHONNOUSERSITE=1

%labels
    org.clinicalsuite.image qc
    org.clinicalsuite.fastqc.version 0.12.1
    org.clinicalsuite.fastp.version 1.3.6
    org.clinicalsuite.multiqc.version 1.35
    org.clinicalsuite.fontconfig.version 2.15.0-2.3
    org.clinicalsuite.fonts.dejavu.version 2.37-8
    org.clinicalsuite.data.embedded false

%test
    set -eu

    fc-match sans >/dev/null
    /usr/local/bin/fastqc --version
    fastp --version
    multiqc --version
