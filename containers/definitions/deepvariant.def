Bootstrap: docker
From: google/deepvariant@sha256:962e5a83b1d76aae6990625d47102785f791603f2138aa1fa9aa4fb6a2eecbe6

%post
    set -eu

    # Models are deployment resources and must be mounted at runtime.
    rm -rf /opt/models /opt/smallmodels
    mkdir -p /opt/models /opt/smallmodels

%environment
    export PATH=/opt/deepvariant/bin:/usr/local/bin:/usr/bin:/bin

%labels
    org.clinicalsuite.image deepvariant
    org.clinicalsuite.deepvariant.version 1.10.0
    org.clinicalsuite.model.embedded false
    org.clinicalsuite.data.embedded false

%test
    set -eu

    help_status=0

    help_output="$(run_deepvariant --help 2>&1)" || help_status=$?
    test "$help_status" -eq 1
    printf '%s\n' "$help_output" | grep -q 'Runs all 3 steps'
    test "$(find /opt/models /opt/smallmodels -type f 2>/dev/null | wc -l)" -eq 0
