Bootstrap: docker
From: quay.io/biocontainers/octopus@sha256:342401712c1cb3f3e63fa01ab931a59bc1801ab75de95f1c2b3fb5b15d643db1

%environment
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    org.clinicalsuite.image octopus
    org.clinicalsuite.octopus.version 0.7.4
    org.clinicalsuite.model.embedded false
    org.clinicalsuite.data.embedded false

%test
    set -eu

    octopus --version
    test "$(find /opt /usr/local -type f \( -iname '*.forest' -o -iname '*.model' \) 2>/dev/null | wc -l)" -eq 0
