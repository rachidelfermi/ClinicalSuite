Bootstrap: docker
From: python@sha256:2986c55feb36e6cae00fa1fefb454283e4b33f35e75ff8bdd123b134130be301

%files
    requirements/report.txt /opt/clinical-requirements/report.txt

%post
    set -eu

    python -m pip install \
        --disable-pip-version-check \
        --no-cache-dir \
        --no-deps \
        --requirement /opt/clinical-requirements/report.txt

%environment
    export MPLCONFIGDIR=/tmp/clinicalsuite-matplotlib
    export PYTHONNOUSERSITE=1
    export PYTHONDONTWRITEBYTECODE=1
    export PATH=/usr/local/bin:/usr/bin:/bin

%labels
    org.clinicalsuite.image report
    org.clinicalsuite.python.version 3.12.12
    org.clinicalsuite.data.embedded false

%test
    set -eu

    python --version
    python -c 'import jinja2, matplotlib, pandas; print("imports-ok")'
