Bootstrap: docker
From: ensemblorg/ensembl-vep@sha256:50760b654d22cb7764c991b89098226fb5c5ff986105831c002d3efd84391203

%post
    set -eu

    # Caches, FASTA files, databases, and optional plugins remain external.
    rm -rf \
        /opt/vep/.vep/Plugins \
        /opt/vep/Plugins \
        /opt/vep/src/ensembl-vep/Plugins \
        /opt/vep/src/ensembl-vep/examples \
        /opt/vep/src/ensembl-vep/nextflow \
        /opt/vep/src/kent-335_base/src/lib/tests \
        /root/.vep
    mkdir -p /data /root/.vep
    find /data -mindepth 1 -delete
    find /opt/vep -type f \
        \( -iname '*.fa' -o -iname '*.fasta' -o -iname '*.vcf' -o -iname '*.vcf.gz' \) \
        -delete

%environment
    export PATH=/opt/vep/src/ensembl-vep:/usr/local/bin:/usr/bin:/bin
    export PERL5LIB=/opt/vep/src/ensembl-vep

%labels
    org.clinicalsuite.image annotation
    org.clinicalsuite.vep.version 116.0
    org.clinicalsuite.plugins.embedded false
    org.clinicalsuite.data.embedded false

%test
    set -eu

    vep --help
    test "$(find /data /root/.vep -type f 2>/dev/null | wc -l)" -eq 0
    test "$(find /opt/vep -type f \( -iname '*.fa' -o -iname '*.fasta' -o -iname '*.vcf' -o -iname '*.vcf.gz' \) 2>/dev/null | wc -l)" -eq 0
