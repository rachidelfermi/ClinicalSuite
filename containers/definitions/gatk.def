Bootstrap: docker
From: quay.io/biocontainers/bcftools@sha256:08f357e20dcf8ca75c06027f66b181f4fd88019fea7959b69047ad1b12b08a0c
Stage: htslib

Bootstrap: docker
From: broadinstitute/gatk@sha256:71b17ee42d149e8ec112603f5305c873ab60d93949ef8bb62a4fff85427f56fb
Stage: final

%files from htslib
    /usr/local /opt/htslib

%post
    set -eu

    for tool in bcftools bgzip htsfile tabix; do
        cat > "/usr/local/bin/$tool" <<EOF
#!/bin/sh
exec /opt/htslib/bin/$tool "\$@"
EOF
        chmod 0755 "/usr/local/bin/$tool"
    done

%environment
    export BCFTOOLS_PLUGINS=/opt/htslib/libexec/bcftools
    export PATH=/usr/local/bin:/gatk:/opt/miniconda/envs/gatk/bin:/opt/miniconda/bin:/usr/bin:/bin

%labels
    org.clinicalsuite.image gatk
    org.clinicalsuite.gatk.version 4.6.2.0
    org.clinicalsuite.bcftools.version 1.24
    org.clinicalsuite.htslib.version 1.24
    org.clinicalsuite.data.embedded false

%test
    set -eu

    gatk --version
    bcftools --version
    htsfile --version
