Bootstrap: docker
From: quay.io/biocontainers/bwa-mem2@sha256:374f4b910b4b04d32772fccd4cab1cdcd0758356856a960cfa8b1edebfd38c9f
Stage: bwa-runtime

Bootstrap: docker
From: quay.io/biocontainers/samtools@sha256:a130447589651ed09252aa95a5e4f4132942cdb54d835d81a04a9a930d656561
Stage: final

%files from bwa-runtime
    /usr/local/lib /opt/bwa-runtime/lib

%files
    .build/sources/bwa-mem2-2.3_x64-linux.tar.bz2 /opt/sources/bwa-mem2.tar.bz2
    .build/sources/picard-3.4.0.jar /opt/sources/picard.jar
    .build/sources/mosdepth-0.3.14 /opt/sources/mosdepth
    .build/sources/OpenJDK17U-jre_x64_linux_hotspot_17.0.19_10.tar.gz /opt/sources/jre.tar.gz

%post
    set -eu

    mkdir -p /opt/bwa-mem2 /opt/java /opt/picard
    tar -xjf /opt/sources/bwa-mem2.tar.bz2 \
        --strip-components=1 -C /opt/bwa-mem2
    tar -xzf /opt/sources/jre.tar.gz --strip-components=1 -C /opt/java

    install -m 0644 /opt/sources/picard.jar /opt/picard/picard.jar
    install -m 0755 /opt/sources/mosdepth /usr/local/bin/mosdepth
    ln -sf /opt/bwa-mem2/bwa-mem2 /usr/local/bin/bwa-mem2

    cat > /usr/local/bin/picard <<'EOF'
#!/bin/sh
exec /opt/java/bin/java ${PICARD_JAVA_OPTIONS:-} -jar /opt/picard/picard.jar "$@"
EOF
    chmod 0755 /usr/local/bin/picard
    rm -rf /opt/sources

%environment
    export JAVA_HOME=/opt/java
    export LD_LIBRARY_PATH=/opt/bwa-runtime/lib
    export PATH=/opt/java/bin:/opt/bwa-mem2:/usr/local/bin:/usr/bin:/bin

%labels
    org.clinicalsuite.image alignment
    org.clinicalsuite.bwa-mem2.version 2.3
    org.clinicalsuite.samtools.version 1.24
    org.clinicalsuite.htslib.version 1.24
    org.clinicalsuite.picard.version 3.4.0
    org.clinicalsuite.mosdepth.version 0.3.14
    org.clinicalsuite.data.embedded false

%test
    set -eu

    picard_status=0

    bwa-mem2 version
    samtools --version
    picard_output="$(picard MarkDuplicates --version 2>&1)" || picard_status=$?
    test "$picard_status" -eq 1
    test "$picard_output" = 'Version:3.4.0'
    mosdepth --version
